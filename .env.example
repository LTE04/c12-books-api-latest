DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=books_api
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4
APP_DEBUG=false

JWT_SECRET=change-me-to-a-long-random-string-please-do-not-commit
JWT_TTL=3600
JWT_ISSUER=books-api

# Ch12 — Rate limiting
LOGIN_RATE_LIMIT=5
LOGIN_WINDOW_SECONDS=60

# Ch12 — CORS allow-list (comma-separated, no spaces)
# Add your Vercel frontend URL here after deploying
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,capacitor://localhost,https://your-frontend.vercel.app
